{
    "name": "phpdot/http",
    "description": "Advanced HTTP library for PHP. PSR-7/17 native. Framework-agnostic.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["http", "request", "response", "psr-7", "psr-17", "cookie", "exception"],
    "require": {
        "php": ">=8.3",
        "nyholm/psr7": "^1.8",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpdot/container": "^1.5",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "phpdot/container": "Required for auto-wiring HttpConfig and ResponseFactory's PSR-17 interfaces via the framework's manifest scanner. The lifecycle attributes are inert at runtime; standalone consumers don't need it installed."
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Http\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Http\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
